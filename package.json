  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.17",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.2.0",
    "jest": "30.2.0",
    "jest-mock-extended": "4.0.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0"
